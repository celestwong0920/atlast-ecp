# ATLAST ECP Server — Environment Variables
# Copy to .env and fill in values

# ── EAS (Ethereum Attestation Service) ──
EAS_PRIVATE_KEY=           # Wallet private key for signing attestations
EAS_SCHEMA_UID=0xa67da7e880b3fe643f0e12b754c6048fc0a0bad0ed9a932ac85a5ebf6bd9326e
EAS_CHAIN=sepolia          # "sepolia" (testnet) or "mainnet" (Base mainnet)
EAS_STUB_MODE=true         # "true" for dev (no real tx), "false" for production

# ── Webhook (to LLaChat) ──
ECP_WEBHOOK_URL=https://api.llachat.com/v1/internal/ecp-webhook
ECP_WEBHOOK_TOKEN=         # Shared secret for HMAC signing

# ── LLaChat Integration ──
LLACHAT_API_URL=https://api.llachat.com
LLACHAT_INTERNAL_TOKEN=    # Service-to-service auth token

# ── Database ──
DATABASE_URL=              # PostgreSQL connection string (e.g., postgresql://user:pass@host:5432/db)

# ── Server ──
PORT=8080
ENVIRONMENT=development    # "development" or "production"

# ── Anchor Scheduling ──
ANCHOR_INTERVAL_MINUTES=60 # How often to anchor pending batches
SUPER_BATCH_MIN_SIZE=5     # Min batches to trigger super-batch aggregation

# ── Monitoring ──
SENTRY_DSN=                # Sentry DSN for error tracking (optional)

# ── CORS ──
# CORS_ORIGINS=https://yourdomain.com,https://docs.weba0.com
