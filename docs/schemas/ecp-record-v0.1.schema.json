{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://weba0.com/schemas/ecp-record-v0.1.json",
  "title": "ECP Record v0.1 (Full/Nested)",
  "description": "Evidence Chain Protocol record — nested format with chain linkage and cryptographic signature.",
  "type": "object",
  "required": ["id", "agent", "ts", "step", "chain", "sig"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^rec_[0-9a-f]{12,32}$"
    },
    "agent": {
      "type": "string",
      "pattern": "^did:ecp:[0-9a-f]{32}$",
      "description": "Agent DID"
    },
    "ts": {
      "type": "integer",
      "description": "Unix timestamp in milliseconds"
    },
    "step": {
      "type": "object",
      "required": ["type", "in_hash", "out_hash"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["llm_call", "tool_call", "message", "turn", "a2a_call"]
        },
        "in_hash": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "out_hash": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "latency_ms": { "type": "integer", "minimum": 0 },
        "flags": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["retried", "hedged", "incomplete", "high_latency", "error", "human_review", "a2a_delegated"]
          }
        },
        "model": { "type": ["string", "null"] },
        "tokens_in": { "type": ["integer", "null"], "minimum": 0 },
        "tokens_out": { "type": ["integer", "null"], "minimum": 0 },
        "cost_usd": { "type": ["number", "null"], "minimum": 0 },
        "parent_agent": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "chain": {
      "type": "object",
      "required": ["prev", "hash"],
      "properties": {
        "prev": {
          "type": "string",
          "description": "'genesis' for first record, else previous record ID"
        },
        "hash": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$",
          "description": "SHA-256 of canonical record JSON"
        }
      },
      "additionalProperties": false
    },
    "sig": {
      "type": "string",
      "pattern": "^(ed25519:[0-9a-f]+|unverified)$",
      "description": "Ed25519 signature or 'unverified'"
    },
    "anchor": {
      "type": "object",
      "properties": {
        "batch_id": { "type": ["string", "null"] },
        "tx_hash": { "type": ["string", "null"] },
        "ts": { "type": ["integer", "null"] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
